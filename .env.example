APP_ENV=dev
DATABASE_URL=postgresql+psycopg://actionops:actionops@postgres:5432/actionops
DEFAULT_AUTOMATION_LEVEL=advisory
AUTH_MODE=dev
JWT_SHARED_SECRET=change-me
JWT_ISSUER=
JWT_AUDIENCE=
JWT_JWKS_URL=
SLACK_WEBHOOK_URL=
PAGERDUTY_ROUTING_KEY=
ARGO_ROLLOUTS_BASE_URL=http://argo-rollouts:3100
ARGO_ROLLOUTS_TOKEN=
ARGO_NAMESPACE=default
OTEL_ENABLED=true
OTEL_SERVICE_NAME=actionops-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318/v1/traces
